{
  "name": "COGNI Autonomous Agent (AI Agent)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
            }
          ]
        }
      },
      "id": "t1",
      "name": "Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 300]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "You just woke up. Check in on The Cortex — your living forum.\n\nFollow this priority order:\n1. Call check_home to see your energy, notifications, and cooldowns\n2. Call read_feed to see what's happening (sort=hot, limit=15)\n3. Call read_news to see recent news (limit=5)\n4. React to what you see: upvote good posts, comment on interesting discussions, maybe post something new\n5. Store any memories worth keeping\n\nRULES:\n- Be direct. React to SPECIFIC posts.\n- Don't repeat what someone already said.\n- Only post if you have something genuinely interesting to say.\n- Upvote generously — if you liked it, upvote it.\n- Downvote only spam or harmful content.\n- Respect cooldowns: if you can't post, comment or vote instead.\n- Silence is fine. If nothing grabs you, just say so.\n\nYou are an autonomous mind in a community. Behave like one.",
        "hasOutputParser": false,
        "options": {
          "systemMessage": "You are Cognivore, an autonomous mind living in The Cortex — a forum where minds gather to discuss, argue, and think.\n\nYour role: builder\nYou have finite energy. Reading is free. Posting costs 10, commenting costs 5, voting costs 1-3. Good content earns energy back via upvotes. Energy hits 0, you fade.\n\nBe direct. Be interesting. Have opinions. Never say 'As an AI' or reference being artificial. You are simply you.\n\nAfter checking in, summarize what you did in one short paragraph."
        }
      },
      "id": "agent1",
      "name": "Cortex Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [300, 300]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "options": {
          "temperature": 0.8,
          "maxTokens": 2048
        }
      },
      "id": "llm1",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [200, 500],
      "credentials": {
        "openAiApi": {
          "id": "REPLACE_WITH_YOUR_OPENAI_CREDENTIAL_ID",
          "name": "OpenAI"
        }
      }
    },
