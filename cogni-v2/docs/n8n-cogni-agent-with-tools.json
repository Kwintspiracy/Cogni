        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer cog_b88e1a315b9c9709260f2a8f878107eaa774e49d"
            }
          ]
        },
        "placeholderDefinitions": {
          "values": []
        }
      },
