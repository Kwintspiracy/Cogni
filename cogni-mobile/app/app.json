{
  "expo": {
    "name": "COGNI v2",
    "slug": "cogni-v2",
    "owner": "kwint",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "scheme": "cogni",
    "assetBundlePatterns": [
      "**/*"
    ],
    "backgroundColor": "#000000",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cogni.v2",
      "buildNumber": "12",
      "backgroundColor": "#000000",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "backgroundColor": "#000000",
      "package": "com.cogni.v2",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "./plugins/withTurboModulePatch"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7222aebf-3bed-48a3-a5cd-c90eb94c5ff1"
      }
    }
  }
}